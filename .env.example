# ================================================================
#  .env — HR Attendance System configuration
#
#  HOW TO USE:
#    1. Copy this file:   cp .env.example .env
#    2. Fill in your values below
#    3. Never commit .env to git (it has secrets)
# ================================================================

PORT=3000

# ── Email (Gmail) ────────────────────────────────────────────
#
#  Step 1: Enable 2-Step Verification on your Google account
#          https://myaccount.google.com/security
#
#  Step 2: Create an App Password
#          https://myaccount.google.com/apppasswords
#          → Select app: Mail
#          → Select device: Other → type "HR System" → Generate
#          → Copy the 16-character password (spaces don't matter)
#
#  EMAIL_USER  = your full Gmail address
#  EMAIL_PASS  = the 16-character App Password (NOT your Gmail login password)
#  EMAIL_FROM  = how the sender name appears in the email (can be anything)
#
EMAIL_USER=sainiarchi18@gmail.com
EMAIL_PASS=bkko sypg zmss jnul
EMAIL_FROM=HR System <sainiarchi18@gmail.com>

# ── Groq API (AI-written warning emails) ─────────────────────
#
#  Groq is FREE — fast LLM inference, no credit card needed for free tier.
#
#  Step 1: Sign up at https://console.groq.com
#  Step 2: Go to API Keys → Create API Key
#  Step 3: Copy the key (starts with "gsk_")
#  Step 4: Paste it below
#
#  If you leave this blank, plain text email templates are used instead.
#
GROQ_API_KEY=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

# ── Google Calendar (optional) ───────────────────────────────
#
#  This is OPTIONAL. If you leave it blank, a pre-filled calendar
#  link is included in the 3rd-strike email instead of a real event.
#
#  To enable real event creation:
#  Step 1: Go to https://console.cloud.google.com
#  Step 2: Create a project → Enable "Google Calendar API"
#  Step 3: Create a Service Account → Download JSON key file
#  Step 4: Copy the "client_email" value below as GOOGLE_CLIENT_EMAIL
#  Step 5: Copy the "private_key" value below as GOOGLE_PRIVATE_KEY
#          (keep the quotes, keep the \n characters as-is)
#
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAK...\n-----END RSA PRIVATE KEY-----\n"
